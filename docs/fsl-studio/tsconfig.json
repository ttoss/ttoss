{
  "extends": "@ttoss/config/tsconfig.json",
  "compilerOptions": {
    /*
     * Keep compiler flags identical to the workspace base: the Studio
     * consumes @ttoss/fsl-ui and @ttoss/fsl-theme via their src/ exports, so
     * tsc type-checks their sources too — and those packages typecheck
     * cleanly under these same flags (their own test scripts run tsc).
     */
    "isolatedModules": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
