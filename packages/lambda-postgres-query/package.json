{
  "name": "@ttoss/lambda-postgres-query",
  "version": "0.6.0",
  "description": "Create a Lambda function that queries a PostgreSQL database.",
  "license": "MIT",
  "author": "ttoss",
  "contributors": [
    "Pedro Arantes <pedro@arantespp.com> (https://arantespp.com)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/ttoss.git",
    "directory": "packages/lambda-postgres-query"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cloudformation": "./src/cloudformation.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "jest --projects tests/unit"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1025.0",
    "@ttoss/cloudformation": "workspace:^",
    "camelcase-keys": "^7.0.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@ttoss/config": "workspace:^",
    "@ttoss/test-utils": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "aws-sdk-client-mock": "^4.1.0",
    "jest": "^30.3.0",
    "tsdown": "^0.21.7"
  },
  "keywords": [
    "aws",
    "cloudformation",
    "lambda"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "require": {
          "default": "./dist/index.cjs",
          "types": "./dist/index.d.cts"
        },
        "import": {
          "default": "./dist/index.mjs",
          "types": "./dist/index.d.mts"
        }
      },
      "./cloudformation": {
        "require": {
          "default": "./dist/cloudformation/index.cjs",
          "types": "./dist/cloudformation/index.d.cts"
        },
        "import": {
          "default": "./dist/cloudformation/index.mjs",
          "types": "./dist/cloudformation/index.d.mts"
        }
      }
    },
    "provenance": true
  }
}
