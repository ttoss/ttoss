{
  "name": "@ttoss/http-server-oauth",
  "version": "0.1.0",
  "description": "OAuth 2.1 plugin for @ttoss/http-server (Koa adapter over @ttoss/auth-core)",
  "keywords": [
    "koa",
    "oauth",
    "oauth2",
    "authorization-server",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/ttoss.git",
    "directory": "packages/http-server-oauth"
  },
  "license": "MIT",
  "author": "ttoss",
  "contributors": [
    "Pedro Arantes <pedro@arantespp.com> (https://arantespp.com)"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "jest --projects tests/unit"
  },
  "dependencies": {
    "@ttoss/auth-core": "workspace:^",
    "@ttoss/http-server": "workspace:^"
  },
  "devDependencies": {
    "@ttoss/config": "workspace:^",
    "@types/koa": "^3.0.3",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "tsdown": "^0.22.2"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs",
        "types": "./dist/index.d.mts"
      }
    },
    "provenance": true
  }
