{
  "extends": "@ttoss/config/tsconfig.json",
  "compilerOptions": {
    "outDir": "build",
    "rootDir": "src",
    "noEmit": false,
    "declaration": false,
    "downlevelIteration": true,
    "sourceMap": false,
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}
