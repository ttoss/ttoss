{
  "id": "raster-dem-map",
  "title": "Raster DEM Map",
  "description": "Map using a raster-dem source to display terrain elevation data with hillshading.",
  "engine": "maplibre",
  "view": {
    "center": [11.39085, 47.27574],
    "zoom": 11,
    "pitch": 52,
    "bearing": 150
  },
  "sources": [
    {
      "id": "terrain-dem",
      "type": "raster-dem",
      "tiles": [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 15,
      "encoding": "terrarium",
      "attribution": "© Mapzen Terrain Tiles, © OpenStreetMap contributors"
    }
  ],
  "layers": [
    {
      "id": "hillshade",
      "sourceId": "terrain-dem",
      "geometry": "raster",
      "visible": true,
      "paint": {
        "rasterOpacity": 0.6
      }
    }
  ]
}
