{
  "id": "vector-tiles-map",
  "title": "Vector Tiles Map",
  "description": "Map using a vector tile source to display streets and roads as line geometries.",
  "engine": "maplibre",
  "view": {
    "center": [13.388, 52.517],
    "zoom": 12
  },
  "basemap": {
    "styleUrl": "https://tiles.openfreemap.org/styles/bright"
  },
  "sources": [
    {
      "id": "streets",
      "type": "vector-tiles",
      "tiles": ["https://tiles.openfreemap.org/planet/{z}/{x}/{y}.pbf"],
      "sourceLayer": "transportation",
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "© OpenMapTiles © OpenStreetMap contributors"
    }
  ],
  "layers": [
    {
      "id": "streets-line",
      "sourceId": "streets",
      "geometry": "line",
      "visible": true,
      "minzoom": 5,
      "maxzoom": 20,
      "paint": {
        "lineColor": "#3d84c6",
        "lineWidth": 2
      }
    }
  ]
}
