{
  "id": "image-map",
  "title": "Image Map",
  "description": "Map using an image source to overlay a georeferenced radar image as a raster layer.",
  "engine": "maplibre",
  "view": {
    "center": [-75.789, 41.874],
    "zoom": 5
  },
  "sources": [
    {
      "id": "radar-image",
      "type": "image",
      "url": "https://maplibre.org/maplibre-gl-js/docs/assets/radar.gif",
      "coordinates": [
        [-80.425, 46.437],
        [-71.516, 46.437],
        [-71.516, 37.936],
        [-80.425, 37.936]
      ],
      "attribution": "© NOAA"
    }
  ],
  "layers": [
    {
      "id": "radar-layer",
      "sourceId": "radar-image",
      "geometry": "raster",
      "visible": true,
      "paint": {
        "rasterOpacity": 0.85,
        "rasterFadeDuration": 0
      }
    }
  ]
}
