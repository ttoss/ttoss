{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ttoss.dev/geovis/spec.schema.json",
  "title": "VisualizationSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "engine", "sources", "layers"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "engine": {
      "type": "string",
      "enum": ["maplibre"]
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "center": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "zoom": {
          "type": "number"
        },
        "pitch": {
          "type": "number"
        },
        "bearing": {
          "type": "number"
        },
        "projection": {
          "type": "string",
          "enum": ["mercator", "vertical-perspective"]
        }
      }
    },
    "basemap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "styleUrl": {
          "type": "string"
        },
        "attribution": {
          "type": "string"
        },
        "visible": {
          "type": "boolean",
          "description": "When false, basemap tiles are hidden. GeoJSON layers remain interactive."
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "data"],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "const": "geojson"
              },
              "data": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "URL pointing to a GeoJSON resource (RFC 7946)"
                  },
                  {
                    "$ref": "#/$defs/FeatureCollection"
                  },
                  {
                    "$ref": "#/$defs/Feature"
                  },
                  {
                    "$ref": "#/$defs/Geometry"
                  }
                ]
              },
              "attribution": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "tiles"],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "const": "vector-tiles"
              },
              "tiles": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "sourceLayer": {
                "type": "string"
              },
              "minzoom": {
                "type": "number"
              },
              "maxzoom": {
                "type": "number"
              },
              "attribution": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "tiles"],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "const": "raster-tiles"
              },
              "tiles": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "tileSize": {
                "type": "integer",
                "enum": [256, 512]
              },
              "minzoom": {
                "type": "number"
              },
              "maxzoom": {
                "type": "number"
              },
              "attribution": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "url", "coordinates"],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "const": "image"
              },
              "url": {
                "type": "string"
              },
              "coordinates": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "maxItems": 2
                }
              },
              "attribution": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type"],
            "anyOf": [
              {
                "required": ["tiles"]
              },
              {
                "required": ["url"]
              }
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "const": "raster-dem"
              },
              "tiles": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "url": {
                "type": "string"
              },
              "tileSize": {
                "type": "number"
              },
              "minzoom": {
                "type": "number"
              },
              "maxzoom": {
                "type": "number"
              },
              "attribution": {
                "type": "string"
              },
              "encoding": {
                "type": "string",
                "enum": ["mapbox", "terrarium", "custom"]
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "urls", "coordinates"],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "const": "video"
              },
              "urls": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "coordinates": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "maxItems": 2
                }
              }
            }
          }
        ]
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sourceId", "geometry"],
        "properties": {
          "id": {
            "type": "string"
          },
          "sourceId": {
            "type": "string"
          },
          "geometry": {
            "type": "string",
            "enum": ["point", "line", "polygon", "raster", "symbol", "heatmap"]
          },
          "sourceLayer": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "visible": {
            "type": "boolean"
          },
          "minzoom": {
            "type": "number"
          },
          "maxzoom": {
            "type": "number"
          },
          "paint": {
            "type": "object",
            "additionalProperties": true
          },
          "legends": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/LegendSpec"
            }
          },
          "activeLegendId": {
            "type": "string",
            "minLength": 1
          },
          "mapDataId": {
            "type": "string",
            "minLength": 1
          },
          "hoverPaint": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lineColor": {
                "type": "string"
              },
              "lineWidth": {
                "type": "number"
              }
            }
          },
          "selectedPaint": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lineColor": {
                "type": "string"
              },
              "lineWidth": {
                "type": "number"
              }
            }
          },
          "clickAnchor": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "iconImage": {
                "type": "string"
              },
              "iconSize": {
                "type": "number"
              },
              "color": {
                "type": "string"
              },
              "offset": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "adapterHints": {},
    "legends": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LegendSpec"
      }
    },
    "mapData": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mapDataId", "mapId", "data"],
        "properties": {
          "mapDataId": {
            "type": "string",
            "minLength": 1
          },
          "mapId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "joinKey": {
            "type": "string",
            "minLength": 1
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["geometryId", "value"],
              "properties": {
                "geometryId": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                "value": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "CategoricalColorBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "property"],
      "properties": {
        "type": {
          "const": "categorical"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "palette": {
          "type": "string"
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "defaultColor": {
          "type": "string"
        }
      }
    },
    "QuantitativeColorBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "property", "scale"],
      "properties": {
        "type": {
          "const": "quantitative"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "scale": {
          "const": "threshold"
        },
        "thresholds": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "palette": {
          "type": "string"
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "defaultColor": {
          "type": "string"
        }
      }
    },
    "ColorBy": {
      "oneOf": [
        {
          "$ref": "#/$defs/CategoricalColorBy"
        },
        {
          "$ref": "#/$defs/QuantitativeColorBy"
        }
      ]
    },
    "LegendSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "colorBy"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "description": "Short heading rendered above the legend swatches."
        },
        "subtitle": {
          "type": "string",
          "description": "Secondary description rendered below the title."
        },
        "labelFormat": {
          "$ref": "#/$defs/LabelFormatSpec"
        },
        "normalization": {
          "$ref": "#/$defs/NormalizationSpec"
        },
        "position": {
          "type": "string",
          "enum": ["top-left", "top-right", "bottom-left", "bottom-right"],
          "description": "Corner position for an absolutely-positioned legend overlay."
        },
        "noDataLabel": {
          "type": "string",
          "description": "Label for the 'no data' swatch. When omitted no entry is shown."
        },
        "reference": {
          "type": "string",
          "description": "Bibliographic attribution. Supports plain text and {link:text|url} syntax for inline links."
        },
        "colorBy": {
          "$ref": "#/$defs/ColorBy"
        }
      }
    },
    "LabelFormatSpec": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "range"
            },
            "separator": {
              "type": "string"
            },
            "unit": {
              "type": "string"
            },
            "extended": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "count"
            },
            "abbreviate": {
              "type": "boolean"
            },
            "extended": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "percentage"
            },
            "decimals": {
              "type": "integer",
              "minimum": 0
            },
            "denominator": {
              "type": "number"
            },
            "extended": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "stdDev"
            },
            "unit": {
              "type": "string",
              "enum": ["σ", "sd"]
            },
            "extended": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "formatter"],
          "properties": {
            "type": {
              "const": "custom"
            },
            "formatter": {
              "description": "Custom formatter function. Not serializable to JSON; use this variant only in TypeScript-driven specs passed directly to GeoVisLegend, not in JSON files."
            },
            "extended": {
              "type": "boolean"
            }
          },
          "description": "Custom formatter (TypeScript-only). The spec object must have a `formatter` property at runtime: (lower: number | null, upper: number | null, index: number) => string. Not serializable to JSON; use this variant only in TypeScript-driven specs passed directly to GeoVisLegend, not in JSON files."
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "labels"],
          "properties": {
            "type": {
              "const": "labels"
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Ordered list of explicit labels, one entry per legend bin. Bins beyond the array length fall back to range-style formatting."
            },
            "extended": {
              "type": "boolean"
            }
          },
          "description": "Explicit label list. JSON-serialisable alternative to 'custom'. Bins without a matching entry fall back to range-style formatting."
        }
      ]
    },
    "NormalizationSpec": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "const": "raw"
            },
            "numeratorLabel": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "numeratorLabel"],
          "anyOf": [
            {
              "required": ["denominatorLabel"]
            }
          ],
          "properties": {
            "type": {
              "const": "ratio"
            },
            "numeratorLabel": {
              "type": "string"
            },
            "denominatorLabel": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "numeratorLabel"],
          "anyOf": [
            {
              "required": ["denominatorLabel"]
            }
          ],
          "properties": {
            "type": {
              "const": "percentage"
            },
            "numeratorLabel": {
              "type": "string"
            },
            "denominatorLabel": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "numeratorLabel", "rateBase"],
          "anyOf": [
            {
              "required": ["denominatorLabel"]
            }
          ],
          "properties": {
            "type": {
              "const": "rate"
            },
            "numeratorLabel": {
              "type": "string"
            },
            "denominatorLabel": {
              "type": "string"
            },
            "rateBase": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        }
      ]
    },
    "Position": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 2
    },
    "LinearRing": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Position"
      },
      "minItems": 4
    },
    "Point": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "$ref": "#/$defs/Position"
        }
      }
    },
    "MultiPoint": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "MultiPoint"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Position"
          }
        }
      }
    },
    "LineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Position"
          },
          "minItems": 2
        }
      }
    },
    "MultiLineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "MultiLineString"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/Position"
            },
            "minItems": 2
          }
        }
      }
    },
    "Polygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "Polygon"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/LinearRing"
          }
        }
      }
    },
    "MultiPolygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "MultiPolygon"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/LinearRing"
            }
          }
        }
      }
    },
    "GeometryCollection": {
      "type": "object",
      "required": ["type", "geometries"],
      "properties": {
        "type": {
          "const": "GeometryCollection"
        },
        "geometries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Geometry"
          }
        }
      }
    },
    "Geometry": {
      "oneOf": [
        {
          "$ref": "#/$defs/Point"
        },
        {
          "$ref": "#/$defs/MultiPoint"
        },
        {
          "$ref": "#/$defs/LineString"
        },
        {
          "$ref": "#/$defs/MultiLineString"
        },
        {
          "$ref": "#/$defs/Polygon"
        },
        {
          "$ref": "#/$defs/MultiPolygon"
        },
        {
          "$ref": "#/$defs/GeometryCollection"
        }
      ]
    },
    "Feature": {
      "type": "object",
      "required": ["type", "geometry", "properties"],
      "properties": {
        "type": {
          "const": "Feature"
        },
        "id": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            }
          ]
        },
        "geometry": {
          "oneOf": [
            {
              "$ref": "#/$defs/Geometry"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "FeatureCollection": {
      "type": "object",
      "required": ["type", "features"],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Feature"
          }
        }
      }
    }
  }
}
