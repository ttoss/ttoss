{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ttoss.dev/geovis/spec.schema.json",
  "title": "VisualizationSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "engine", "view", "data", "layers"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "engine": {
      "type": "string",
      "enum": ["maplibre"]
    },
    "view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["center", "zoom"],
      "properties": {
        "center": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "zoom": {
          "type": "number"
        },
        "pitch": {
          "type": "number"
        },
        "bearing": {
          "type": "number"
        },
        "projection": {
          "type": "string",
          "enum": ["mercator", "vertical-perspective"]
        },
        "autoFit": {
          "type": "boolean"
        }
      }
    },
    "basemap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "styleUrl": {
          "type": "string"
        },
        "attribution": {
          "type": "string"
        }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "dataId", "geometry"],
        "properties": {
          "id": {
            "type": "string"
          },
          "geometry": {
            "type": "string",
            "enum": ["point", "line", "polygon", "raster", "symbol", "heatmap"]
          },
          "sourceLayer": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "visible": {
            "type": "boolean"
          },
          "minzoom": {
            "type": "number"
          },
          "maxzoom": {
            "type": "number"
          },
          "paint": {
            "type": "object",
            "additionalProperties": true
          },
          "labelProperty": {
            "type": "string",
            "minLength": 1
          },
          "displayProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "displayPropertyLabels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "colorBy": {
            "$ref": "#/$defs/ColorBy"
          },
          "legends": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/LegendSpec"
            }
          },
          "activeLegendId": {
            "type": "string",
            "minLength": 1
          },
          "dataId": {
            "type": "string"
          }
        }
      }
    },
    "views": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "layers"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "layers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "layerTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LayerTemplate"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "adapterHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maplibre": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "styleVersion": {
              "type": "integer",
              "const": 8
            }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DataEntry"
      }
    }
  },
  "$defs": {
    "Position": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 2
    },
    "LinearRing": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Position"
      },
      "minItems": 4
    },
    "Point": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "$ref": "#/$defs/Position"
        }
      }
    },
    "MultiPoint": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "MultiPoint"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Position"
          }
        }
      }
    },
    "LineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Position"
          },
          "minItems": 2
        }
      }
    },
    "MultiLineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "MultiLineString"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/Position"
            },
            "minItems": 2
          }
        }
      }
    },
    "Polygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "Polygon"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/LinearRing"
          }
        }
      }
    },
    "MultiPolygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "properties": {
        "type": {
          "const": "MultiPolygon"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/LinearRing"
            }
          }
        }
      }
    },
    "GeometryCollection": {
      "type": "object",
      "required": ["type", "geometries"],
      "properties": {
        "type": {
          "const": "GeometryCollection"
        },
        "geometries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Geometry"
          }
        }
      }
    },
    "Geometry": {
      "oneOf": [
        {
          "$ref": "#/$defs/Point"
        },
        {
          "$ref": "#/$defs/MultiPoint"
        },
        {
          "$ref": "#/$defs/LineString"
        },
        {
          "$ref": "#/$defs/MultiLineString"
        },
        {
          "$ref": "#/$defs/Polygon"
        },
        {
          "$ref": "#/$defs/MultiPolygon"
        },
        {
          "$ref": "#/$defs/GeometryCollection"
        }
      ]
    },
    "Feature": {
      "type": "object",
      "required": ["type", "geometry", "properties"],
      "properties": {
        "type": {
          "const": "Feature"
        },
        "id": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            }
          ]
        },
        "geometry": {
          "oneOf": [
            {
              "$ref": "#/$defs/Geometry"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "FeatureCollection": {
      "type": "object",
      "required": ["type", "features"],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Feature"
          }
        }
      }
    },
    "CategoricalColorBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "property"],
      "properties": {
        "type": {
          "const": "categorical"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "palette": {
          "type": "string",
          "minLength": 1
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "defaultColor": {
          "type": "string"
        }
      }
    },
    "QuantitativeColorBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "property", "scale"],
      "properties": {
        "type": {
          "const": "quantitative"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "scale": {
          "type": "string",
          "enum": ["quantile", "quantize", "linear", "threshold"]
        },
        "bins": {
          "type": "integer",
          "minimum": 1
        },
        "thresholds": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 1
        },
        "palette": {
          "type": "string",
          "minLength": 1
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "defaultColor": {
          "type": "string"
        }
      }
    },
    "ColorBy": {
      "oneOf": [
        {
          "$ref": "#/$defs/CategoricalColorBy"
        },
        {
          "$ref": "#/$defs/QuantitativeColorBy"
        }
      ]
    },
    "LegendSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "colorBy"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "colorBy": {
          "$ref": "#/$defs/ColorBy"
        }
      }
    },
    "CategoricalColorByTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "const": "categorical"
        },
        "palette": {
          "type": "string",
          "minLength": 1
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "defaultColor": {
          "type": "string"
        }
      }
    },
    "QuantitativeColorByTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "scale"],
      "properties": {
        "type": {
          "const": "quantitative"
        },
        "scale": {
          "type": "string",
          "enum": ["quantile", "quantize", "linear", "threshold"]
        },
        "bins": {
          "type": "integer",
          "minimum": 1
        },
        "thresholds": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 1
        },
        "palette": {
          "type": "string",
          "minLength": 1
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "defaultColor": {
          "type": "string"
        }
      }
    },
    "ColorByTemplate": {
      "oneOf": [
        {
          "$ref": "#/$defs/CategoricalColorByTemplate"
        },
        {
          "$ref": "#/$defs/QuantitativeColorByTemplate"
        }
      ]
    },
    "LayerTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dataId", "geometry", "properties"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "geometry": {
          "type": "string",
          "enum": ["point", "line", "polygon", "raster", "symbol", "heatmap"]
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "labelProperty": {
          "type": "string",
          "minLength": 1
        },
        "displayProperties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceLayer": {
          "type": "string"
        },
        "visible": {
          "type": "boolean"
        },
        "minzoom": {
          "type": "number"
        },
        "maxzoom": {
          "type": "number"
        },
        "paint": {
          "type": "object",
          "additionalProperties": true
        },
        "colorBy": {
          "$ref": "#/$defs/ColorByTemplate"
        },
        "generateViews": {
          "type": "boolean"
        },
        "layerIdPattern": {
          "type": "string",
          "minLength": 1
        },
        "viewIdPattern": {
          "type": "string",
          "minLength": 1
        },
        "labelPattern": {
          "type": "string",
          "minLength": 1
        },
        "dataId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "DataEntry": {
      "type": "object",
      "required": ["id", "kind"],
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["id", "kind", "geojson"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "geojson-inline"
            },
            "geojson": {
              "oneOf": [
                {
                  "$ref": "#/$defs/FeatureCollection"
                },
                {
                  "$ref": "#/$defs/Feature"
                },
                {
                  "$ref": "#/$defs/Geometry"
                }
              ]
            },
            "attribution": {
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind", "url"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "geojson-url"
            },
            "url": {
              "type": "string"
            },
            "attribution": {
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind", "tiles"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "vector-tiles"
            },
            "tiles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "sourceLayer": {
              "type": "string"
            },
            "minzoom": {
              "type": "number"
            },
            "maxzoom": {
              "type": "number"
            },
            "attribution": {
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind", "tiles"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "raster-tiles"
            },
            "tiles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "tileSize": {
              "type": "integer",
              "enum": [256, 512]
            },
            "minzoom": {
              "type": "number"
            },
            "maxzoom": {
              "type": "number"
            },
            "attribution": {
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind"],
          "anyOf": [
            {
              "required": ["tiles"]
            },
            {
              "required": ["url"]
            }
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "raster-dem"
            },
            "tiles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "url": {
              "type": "string"
            },
            "tileSize": {
              "type": "number"
            },
            "minzoom": {
              "type": "number"
            },
            "maxzoom": {
              "type": "number"
            },
            "attribution": {
              "type": "string"
            },
            "encoding": {
              "type": "string",
              "enum": ["mapbox", "terrarium", "custom"]
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind", "url", "coordinates"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "image"
            },
            "url": {
              "type": "string"
            },
            "coordinates": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "maxItems": 2
              }
            },
            "attribution": {
              "type": "string"
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind", "urls", "coordinates"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "video"
            },
            "urls": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "coordinates": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        },
        {
          "additionalProperties": false,
          "required": ["id", "kind", "engine", "spec"],
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "const": "native"
            },
            "engine": {
              "type": "string",
              "minLength": 1
            },
            "spec": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ]
    }
  }
}
