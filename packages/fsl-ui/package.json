{
  "name": "@ttoss/fsl-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Semantic, token-native component library for the ttoss ecosystem. Built on React Aria Components with @ttoss/fsl-theme tokens.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/ttoss.git",
    "directory": "packages/fsl-ui"
  },
  "license": "MIT",
  "author": "ttoss",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./semantics": "./src/semantics/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "jest --projects tests/unit"
  },
  "dependencies": {
    "@ttoss/fsl-theme": "workspace:^",
    "react-aria-components": "^1.9.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@ttoss/config": "workspace:^",
    "@ttoss/test-utils": "workspace:^",
    "jest": "^30.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "^0.22.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "module": "./dist/index.mjs",
        "browser": "./dist/index.mjs",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./semantics": {
        "types": "./dist/semantics/index.d.mts",
        "default": "./dist/semantics/index.mjs"
      }
    },
    "provenance": true
  }
}
