{
  "name": "@ttoss/fsl-ui",
  "version": "0.2.5",
  "description": "Semantic, token-native component library for the ttoss ecosystem. Built on React Aria Components with @ttoss/fsl-theme tokens.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/ttoss.git",
    "directory": "packages/fsl-ui"
  },
  "license": "MIT",
  "author": "Ennio Lopes <enniolopes@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./semantics": "./src/semantics/index.ts"
  },
  "files": [
    "dist",
    "llms.txt",
    "src/tokens/CONTRACT.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "tsc --noEmit -p tsconfig.json && jest --projects tests/unit",
    "verify:treeshake": "node scripts/verify-treeshake.mjs"
  },
  "dependencies": {
    "@iconify-icon/react": "^2.2.0",
    "@iconify/icons-lucide": "^1.2.135",
    "@ttoss/fsl-theme": "workspace:^",
    "react-aria-components": "~1.19.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@ttoss/config": "workspace:^",
    "@ttoss/forms": "workspace:^",
    "@ttoss/test-utils": "workspace:^",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.2",
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.71.1",
    "tsdown": "^0.22.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "module": "./dist/index.mjs",
        "browser": "./dist/index.mjs",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./semantics": {
        "types": "./dist/semantics/index.d.mts",
        "default": "./dist/semantics/index.mjs"
      }
    },
    "provenance": true
  }
}
