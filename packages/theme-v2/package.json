{
  "private": true,
  "name": "@ttoss/theme2",
  "version": "1.1.11",
  "description": "Theme v2 for packages.",
  "license": "MIT",
  "author": "ttoss",
  "contributors": [
    "Ennio Politi Lopes <enniolopes@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/ttoss.git",
    "directory": "packages/theme-v2"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./css": "./src/css.ts",
    "./runtime": "./src/runtime-entry.ts",
    "./react": "./src/react.tsx",
    "./vars": "./src/vars.ts",
    "./dtcg": "./src/dtcg.ts",
    "./dataviz": "./src/dataviz/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest --projects tests/unit"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@ttoss/config": "workspace:^",
    "@ttoss/test-utils": "workspace:^",
    "jest": "^30.3.0",
    "react": "^19.2.4",
    "tsup": "^8.5.1"
  },
  "keywords": [
    "css-variables",
    "dark-mode",
    "design-tokens",
    "dtcg",
    "react",
    "ssr",
    "theming",
    "ttoss"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "./css": {
        "types": "./dist/css.d.ts",
        "default": "./dist/esm/css.js"
      },
      "./runtime": {
        "types": "./dist/runtime-entry.d.ts",
        "default": "./dist/esm/runtime-entry.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "default": "./dist/esm/react.js"
      },
      "./vars": {
        "types": "./dist/vars.d.ts",
        "default": "./dist/esm/vars.js"
      },
      "./dtcg": {
        "types": "./dist/dtcg.d.ts",
        "default": "./dist/esm/dtcg.js"
      },
      "./dataviz": {
        "types": "./dist/dataviz/index.d.ts",
        "default": "./dist/esm/dataviz/index.js"
      }
    },
    "provenance": true
  }
}
