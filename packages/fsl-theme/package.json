{
  "name": "@ttoss/fsl-theme",
  "version": "1.1.19",
  "description": "ttoss theme provider for UI.",
  "keywords": [
    "css-variables",
    "dark-mode",
    "design-tokens",
    "dtcg",
    "react",
    "ssr",
    "theming",
    "ttoss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/ttoss.git",
    "directory": "packages/fsl-theme"
  },
  "license": "MIT",
  "author": "ttoss",
  "contributors": [
    "Ennio Politi Lopes <enniolopes@gmail.com>"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./css": "./src/css.ts",
    "./runtime": "./src/runtime-entry.ts",
    "./react": "./src/react.tsx",
    "./vars": "./src/vars.ts",
    "./dtcg": "./src/dtcg.ts",
    "./dataviz": "./src/dataviz/index.ts"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsdown",
    "build:verify": "pnpm run build && tsx scripts/probe-jsdoc-propagation.ts",
    "test": "jest --projects tests/unit"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@ttoss/config": "workspace:^",
    "@ttoss/test-utils": "workspace:^",
    "jest": "^30.4.2",
    "react": "^19.2.6",
    "ts-morph": "^28.0.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "module": "./dist/index.mjs",
        "browser": "./dist/index.mjs",
        "import": "./dist/index.mjs",
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./css": {
        "module": "./dist/css.mjs",
        "browser": "./dist/css.mjs",
        "import": "./dist/css.mjs",
        "types": "./dist/css.d.mts",
        "default": "./dist/css.mjs"
      },
      "./runtime": {
        "module": "./dist/runtime-entry.mjs",
        "browser": "./dist/runtime-entry.mjs",
        "import": "./dist/runtime-entry.mjs",
        "types": "./dist/runtime-entry.d.mts",
        "default": "./dist/runtime-entry.mjs"
      },
      "./react": {
        "module": "./dist/react.mjs",
        "browser": "./dist/react.mjs",
        "import": "./dist/react.mjs",
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      },
      "./vars": {
        "module": "./dist/vars.mjs",
        "browser": "./dist/vars.mjs",
        "import": "./dist/vars.mjs",
        "types": "./dist/vars.d.mts",
        "default": "./dist/vars.mjs"
      },
      "./dtcg": {
        "module": "./dist/dtcg.mjs",
        "browser": "./dist/dtcg.mjs",
        "import": "./dist/dtcg.mjs",
        "types": "./dist/dtcg.d.mts",
        "default": "./dist/dtcg.mjs"
      },
      "./dataviz": {
        "module": "./dist/dataviz/index.mjs",
        "browser": "./dist/dataviz/index.mjs",
        "import": "./dist/dataviz/index.mjs",
        "types": "./dist/dataviz/index.d.mts",
        "default": "./dist/dataviz/index.mjs"
      }
    },
    "provenance": true
  }
}
