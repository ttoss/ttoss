{
  "$schema": "./node_modules/turbo/schema.json",
  "concurrency": "4",
  "globalEnv": ["NODE_ENV", "TTOSS_MONOREPO"],
  "tasks": {
    "build-config": {
      "dependsOn": ["^build-config"],
      "outputs": ["dist/**"]
    },
    "i18n": {
      "dependsOn": ["@ttoss/i18n-cli#build-config"],
      "outputs": ["i18n/**"]
    },
    "build": {
      "dependsOn": ["^build", "i18n"],
      "outputs": ["dist/**", "build/**", ".next/**", "storybook-static/**"]
    },
    "@docs/website#build": {
      "dependsOn": ["^build", "i18n"],
      "inputs": [
        "**/*",
        "$TURBO_ROOT$/packages/*/README.md",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/package.json"
      ],
      "outputs": ["build/**"]
    },
    "@docs/website#deploy": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*",
        "$TURBO_ROOT$/packages/*/README.md",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/package.json"
      ],
      "env": ["AWS_*", "CARLIN_*", "ENVIRONMENT"],
      "outputs": [".carlin/**"]
    },
    "test": {
      "dependsOn": ["i18n", "build-config"],
      "outputs": []
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["i18n", "build", "carlin#build", "^deploy"],
      "env": ["AWS_*", "CARLIN_*", "ENVIRONMENT"],
      "outputs": [".carlin/**"]
    }
  }
}
